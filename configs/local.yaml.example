# Local API-only overrides. Do not store real API keys here.
# Put real keys in environment variables such as DEEPSEEK_API_KEY.
providers:
  default: deepseek
  deepseek:
    type: openai-compatible
    model: deepseek-v4-flash
    base_url: https://api.deepseek.com
    api_key_env: DEEPSEEK_API_KEY
